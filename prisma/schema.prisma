generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model card {
  id                        Int                         @id @default(autoincrement())
  deck_id                   Int
  code                      String                      @unique @db.VarChar(255)
  power                     Int?
  type_id                   Int
  range_id                  Int?
  image_url                 String?                     @db.VarChar(255)
  is_deck_card              Boolean                     @default(true)
  deck                      deck                        @relation(fields: [deck_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_deck")
  card_range                card_range?                 @relation(fields: [range_id], references: [id], onUpdate: NoAction, map: "fk_card_range")
  card_type                 card_type                   @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_type")
  card_ability_relationship card_ability_relationship[]
  card_translation          card_translation[]

  @@index([deck_id], map: "idx_card_deck_id")
  @@index([range_id], map: "idx_card_range_id")
  @@index([type_id], map: "idx_card_type_id")
}

model card_ability {
  id                        Int                         @id @default(autoincrement())
  code                      String                      @unique @db.VarChar(255)
  card_ability_relationship card_ability_relationship[]
  card_ability_translation  card_ability_translation[]
}

model card_ability_relationship {
  card_id         Int
  card_ability_id Int
  card_ability    card_ability @relation(fields: [card_ability_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_car_ability")
  card            card         @relation(fields: [card_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_car_card")

  @@id([card_id, card_ability_id], map: "pk_card_ability_relationship")
  @@index([card_ability_id], map: "idx_card_ability_relationship_card_ability_id")
}

model card_ability_translation {
  id              Int          @id @default(autoincrement())
  language_id     Int
  card_ability_id Int
  name            String       @db.VarChar(255)
  description     String?
  card_ability    card_ability @relation(fields: [card_ability_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_ability_translation_ability")
  language        language     @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_ability_translation_language")

  @@unique([card_ability_id, language_id], map: "uq_card_ability_translation")
  @@index([card_ability_id], map: "idx_card_ability_translation_ability_id")
  @@index([language_id], map: "idx_card_ability_translation_language_id")
}

model card_range {
  id                     Int                      @id @default(autoincrement())
  code                   String                   @unique @db.VarChar(255)
  card                   card[]
  card_range_translation card_range_translation[]
}

model card_range_translation {
  id            Int        @id @default(autoincrement())
  language_id   Int
  card_range_id Int
  name          String     @db.VarChar(255)
  description   String?
  language      language   @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_range_translation_language")
  card_range    card_range @relation(fields: [card_range_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_range_translation_range")

  @@unique([card_range_id, language_id], map: "uq_card_range_translation")
  @@index([language_id], map: "idx_card_range_translation_language_id")
  @@index([card_range_id], map: "idx_card_range_translation_range_id")
}

model card_translation {
  id          Int      @id @default(autoincrement())
  language_id Int
  card_id     Int
  name        String   @db.VarChar(255)
  description String?
  card        card     @relation(fields: [card_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_translation_card")
  language    language @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_translation_language")

  @@unique([card_id, language_id], map: "uq_card_translation")
  @@index([card_id], map: "idx_card_translation_card_id")
  @@index([language_id], map: "idx_card_translation_language_id")
}

model card_type {
  id                    Int                     @id @default(autoincrement())
  code                  String                  @unique @db.VarChar(255)
  card                  card[]
  card_type_translation card_type_translation[]
}

model card_type_translation {
  id           Int       @id @default(autoincrement())
  language_id  Int
  card_type_id Int
  name         String    @db.VarChar(255)
  description  String?
  language     language  @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_type_translation_language")
  card_type    card_type @relation(fields: [card_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_card_type_translation_type")

  @@unique([card_type_id, language_id], map: "uq_card_type_translation")
  @@index([language_id], map: "idx_card_type_translation_language_id")
  @@index([card_type_id], map: "idx_card_type_translation_type_id")
}

model deck {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(255)
  game_id          Int
  ability_id       Int?
  card             card[]
  deck_ability     deck_ability?      @relation(fields: [ability_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_ability")
  game             game               @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_game")
  deck_translation deck_translation[]

  @@index([ability_id], map: "idx_deck_ability_id")
  @@index([game_id], map: "idx_deck_game_id")
}

model deck_ability {
  id                       Int                        @id @default(autoincrement())
  code                     String                     @unique @db.VarChar(255)
  deck                     deck[]
  deck_ability_translation deck_ability_translation[]
}

model deck_ability_translation {
  id              Int          @id @default(autoincrement())
  language_id     Int
  deck_ability_id Int
  name            String       @db.VarChar(255)
  description     String?
  deck_ability    deck_ability @relation(fields: [deck_ability_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_ability_translation_ability")
  language        language     @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_ability_translation_language")

  @@unique([deck_ability_id, language_id], map: "uq_deck_ability_translation")
  @@index([deck_ability_id], map: "idx_deck_ability_translation_ability_id")
  @@index([language_id], map: "idx_deck_ability_translation_language_id")
}

model deck_translation {
  id          Int      @id @default(autoincrement())
  language_id Int
  deck_id     Int
  name        String   @db.VarChar(255)
  description String?
  deck        deck     @relation(fields: [deck_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_translation_deck")
  language    language @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_deck_translation_language")

  @@unique([deck_id, language_id], map: "uq_deck_translation")
  @@index([deck_id], map: "idx_deck_translation_deck_id")
  @@index([language_id], map: "idx_deck_translation_language_id")
}

model game {
  id               Int                @id @default(autoincrement())
  code             String             @unique @db.VarChar(255)
  deck             deck[]
  game_translation game_translation[]
}

model game_translation {
  id          Int      @id @default(autoincrement())
  language_id Int
  game_id     Int
  name        String   @db.VarChar(255)
  description String?
  game        game     @relation(fields: [game_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_game_translation_game")
  language    language @relation(fields: [language_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_game_translation_language")

  @@unique([game_id, language_id], map: "uq_game_translation")
  @@index([game_id], map: "idx_game_translation_game_id")
  @@index([language_id], map: "idx_game_translation_language_id")
}

model language {
  id                       Int                        @id @default(autoincrement())
  code                     String                     @unique @db.VarChar(5)
  name                     String                     @db.VarChar(50)
  card_ability_translation card_ability_translation[]
  card_range_translation   card_range_translation[]
  card_translation         card_translation[]
  card_type_translation    card_type_translation[]
  deck_ability_translation deck_ability_translation[]
  deck_translation         deck_translation[]
  game_translation         game_translation[]
}
